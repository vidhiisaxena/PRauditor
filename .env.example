# PRAuditor backend configuration. Copy to .env and fill in.
# (The frontend has its own frontend/.env.example.)

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/prauditor

# --- GitHub App -------------------------------------------------------------
GITHUB_APP_ID=
# Provide the private key contents directly (recommended for deployments)...
GITHUB_PRIVATE_KEY=
# ...or point to a .pem file instead (do NOT commit the file):
# GITHUB_PRIVATE_KEY_PATH=./backend/your-app.private-key.pem
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# --- LLM (any OpenAI-compatible chat completions endpoint) ------------------
GPT_API_URL=https://api.openai.com/v1/chat/completions
GPT_API_KEY=
GPT_MODEL=gpt-4o-mini

# --- Server -----------------------------------------------------------------
# Comma-separated allowed browser origins (add your Vercel URL in production).
CORS_ORIGINS=http://localhost:3000
HOST=0.0.0.0
PORT=8000
ENV=development
