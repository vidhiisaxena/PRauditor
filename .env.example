# PRAuditor backend configuration. Copy to .env and fill in.
# (The frontend has its own frontend/.env.example.)

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/prauditor

# --- GitHub App -------------------------------------------------------------
GITHUB_APP_ID=
# Provide the private key contents directly (recommended for deployments)...
GITHUB_PRIVATE_KEY=
# ...or point to a .pem file instead (do NOT commit the file):
# GITHUB_PRIVATE_KEY_PATH=./backend/your-app.private-key.pem
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# --- GitHub OAuth (user login) ---------------------------------------------
# From your GitHub App / OAuth App. The callback URL must be registered there.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/api/auth/github/callback
# Where users land after login (your frontend). No trailing slash.
FRONTEND_URL=http://localhost:3000

# --- Session JWT ------------------------------------------------------------
# Secret for signing the login session token. Use a long random value.
JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=10080   # optional, default 7 days

# --- LLM (any OpenAI-compatible chat completions endpoint) ------------------
GPT_API_URL=https://api.openai.com/v1/chat/completions
GPT_API_KEY=
GPT_MODEL=gpt-4o-mini

# --- Server -----------------------------------------------------------------
# Comma-separated allowed browser origins (add your Vercel URL in production).
CORS_ORIGINS=http://localhost:3000
HOST=0.0.0.0
PORT=8000
ENV=development
